# =========================
# INDICATORS
# =========================

def rsi(data):
    delta = np.diff(data)
    gain = np.mean([x for x in delta if x > 0])
    loss = np.mean([abs(x) for x in delta if x < 0])

    if loss == 0:
        return 100

    rs = gain / loss
    return 100 - (100 / (1 + rs))

def ema(data, period):
    return pd.Series(data).ewm(span=period).mean().iloc[-1]

# =========================
# AI SCORING ENGINE
# =========================

def score(rsi_val, ema_fast, ema_slow, volatility):

    score = 0

    if rsi_val < 30 or rsi_val > 70:
        score += 30

    if ema_fast > ema_slow:
        score += 30

    if abs(ema_fast - ema_slow) > 0.0005:
        score += 20

    if volatility > 0.001:
        score += 20

    return score

